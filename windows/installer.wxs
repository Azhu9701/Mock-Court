<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="万民幡"
           Manufacturer="Soul Banner"
           Version="0.1.0"
           UpgradeCode="A3F8B2D1-6C4E-4F9A-B8D2-1E7C5F3A9B6D"
           Scope="perMachine"
           Language="2052">

    <MajorUpgrade DowngradeErrorMessage="已安装更新版本。" />
    <MediaTemplate EmbedCab="yes" />

    <WixVariable Id="WixUILicenseRtf" Value="license.rtf" />
    <WixVariable Id="WixUIDialogBmp" Value="dialog.bmp" />
    <WixVariable Id="WixUIBannerBmp" Value="banner.bmp" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="万民幡">
        <Component Id="ApiExe" Guid="B1D3F5A7-9C2E-4B8D-A6F1-3E5C7D9B1A4C">
          <File Id="ApiFile" Source="dist\万民幡\万民幡-api.exe" KeyPath="yes" />
        </Component>
        <Component Id="StartBat" Guid="C2E4F6B8-AD3F-4C9E-B7F2-4F6D8EAC2B5D">
          <File Id="BatFile" Source="dist\万民幡\start.bat" KeyPath="yes" />
        </Component>
        <Component Id="ConfigFile" Guid="D3F5A7C9-BE4A-4DAF-C8A3-5A7E9FBD3C6E">
          <File Id="ConfigYaml" Source="dist\万民幡\config.yaml" KeyPath="yes" />
        </Component>
        <Component Id="Shortcut" Guid="F1B2C3D4-E5F6-7890-ABCD-EF1234567890">
          <Shortcut Id="StartMenuShortcut"
                    Name="万民幡"
                    Description="多 AI 人格并行推理系统"
                    Target="[INSTALLFOLDER]start.bat"
                    WorkingDirectory="INSTALLFOLDER"
                    Directory="ProgramMenuFolder" />
          <RegistryValue Root="HKCU"
                         Key="Software\SoulBanner\万民幡"
                         Name="installed"
                         Value="1"
                         Type="integer"
                         KeyPath="yes" />
        </Component>
        <Directory Id="FrontendDir" Name="frontend" />
        <Directory Id="DataDir" Name="data">
          <Directory Id="SoulsDir" Name="souls" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <ComponentGroup Id="FrontendFiles" Directory="FrontendDir"
                    Source="dist\万民幡\frontend\">
      <Files Include="**\*" />
    </ComponentGroup>

    <ComponentGroup Id="SoulFiles" Directory="SoulsDir"
                    Source="dist\万民幡\data\souls\">
      <Files Include="**\*.md" />
    </ComponentGroup>

    <Feature Id="MainFeature" Title="万民幡" Level="1"
             Description="多 AI 人格并行推理系统" Display="expand"
             ConfigurableDirectory="INSTALLFOLDER">
      <ComponentRef Id="ApiExe" />
      <ComponentRef Id="StartBat" />
      <ComponentRef Id="ConfigFile" />
      <ComponentRef Id="Shortcut" />
      <ComponentGroupRef Id="FrontendFiles" />
      <ComponentGroupRef Id="SoulFiles" />
    </Feature>

    <ui:WixUI Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

  </Package>
</Wix>
