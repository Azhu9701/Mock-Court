# {{domain_name}} 领域配置
#
# 这是 domain.yaml 的骨架模板。
# 用 snake init --domain {{domain_name}} 生成时自动填充。

domain:
  name: "{{domain_name}}"
  icon: "🤖"
  system_name: "{{system_name}}"
  agent_noun: "{{agent_noun}}"
  user_title: "{{user_title}}"
  synthesis_verb: "综合分析"

# 坐标维度：定义你领域中 Agent 的分类体系
# 每个维度有若干离散值，Agent 配置中引用这些值
dimensions:
  - id: "category"
    label: "领域"
    description: "专业领域分类"
    values:
      - "技术"
      - "商业"
      - "设计"
      - "运营"
    weight: 1.0

# 综合 Prompt 模板（Handlebars 语法）
# 所有 Agent 输出完毕后，调用此模板生成综合意见
synthesis:
  template: |
    你是一位系统协调人，负责综合以下{{agent_count}}位{{agent_noun}}的分析。
    
    ## 用户任务
    {{task}}
    
    ## 各位{{agent_noun}}的分析
    {{#agents}}
    ### {{name}}
    {{output}}
    {{/agents}}
    
    ## 碰撞检测结果
    - 矛盾点：{{contradictions}}
    - 互补点：{{complements}}
    - 盲区：{{blindspots}}
    
    请完成综合分析，包含：
    1. 各位{{agent_noun}}的核心观点摘要
    2. 共识与分歧
    3. 综合建议（按优先级排序）
    4. 需要进一步确认的问题

# Collect 阶段的引导语
collect_intro: |
  我将帮助你创建一位新的{{agent_noun}}。
  请描述你希望这位{{agent_noun}}具备的专业领域、分析风格和擅长方向。
  越具体越好——我会据此生成立体、可用的{{agent_noun}}配置。

# Triage 关键词映射
# 用于自动判断用户输入适合哪种推理模式
trigger_markers:
  single:
    - "简单"
    - "快速"
    - "一句话"
    - "什么是"
  conference:
    - "分析"
    - "综合"
    - "多角度"
    - "全面"
    - "评估"
  debate:
    - "辩论"
    - "对比"
    - "选择"
    - "优缺点"
    - "哪个好"
  relay:
    - "步骤"
    - "流程"
    - "方案"
    - "计划"
    - "怎么做"
  learn:
    - "学习"
    - "教我"
    - "解释"
    - "原理"
    - "为什么"
  practice:
    - "实践"
    - "操作"
    - "执行"
    - "实施"

# 记忆配置
memory:
  default_share: "session"    # none | session | all
  max_turns: 20               # 每 Agent 保留最近 N 轮记忆
  persist: true               # 是否持久化到 SQLite
