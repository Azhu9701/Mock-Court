# ── 部署前将 example.com 替换为你的域名 ──
# ── 生成 bcrypt: htpasswd -nbB "" "yourpassword" | cut -d: -f2 ──

DOMAIN=example.com

# Tinyauth
TINYAUTH_SECRET=change-me-to-random-32-char-string
TINYAUTH_ADMIN_USER=admin
TINYAUTH_ADMIN_PASSWORD_HASH=change-me

# Optional OAuth
# TINYAUTH_GITHUB_CLIENT_ID=
# TINYAUTH_GITHUB_CLIENT_SECRET=
# TINYAUTH_GOOGLE_CLIENT_ID=
# TINYAUTH_GOOGLE_CLIENT_SECRET=

# LiteLLM 中转站 — 所有 AI 调用走这里，统一管 key、记用量、控成本
LITELLM_MASTER_KEY=change-me-to-random-key
DEEPSEEK_API_KEY=sk-your-deepseek-key
CLAUDE_API_KEY=sk-your-claude-key
# OPENAI_API_KEY=sk-your-openai-key
