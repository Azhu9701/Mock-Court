# ── 部署前将 example.com 替换为你的域名 ──
# ── 将 ADMIN_PASSWORD_HASH 替换为 bcrypt hash ──
# ── 生成 bcrypt: python3 -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())" ──

DOMAIN=example.com

# Tinyauth
TINYAUTH_SECRET=change-me-to-random-32-char-string
TINYAUTH_ADMIN_USER=admin
# bcrypt hash of your password (generate with: htpasswd -nbB "" "yourpassword" | cut -d: -f2)
TINYAUTH_ADMIN_PASSWORD_HASH=change-me

# Optional: OAuth (GitHub / Google)
# TINYAUTH_GITHUB_CLIENT_ID=
# TINYAUTH_GITHUB_CLIENT_SECRET=
# TINYAUTH_GOOGLE_CLIENT_ID=
# TINYAUTH_GOOGLE_CLIENT_SECRET=
