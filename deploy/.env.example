# ── 部署前将 example.com 替换为你的域名 ──
DOMAIN=example.com

# ── Tinyauth 登录 ──
TINYAUTH_SECRET=change-me-to-random-32-char-string
TINYAUTH_ADMIN_USER=admin
TINYAUTH_ADMIN_PASSWORD_HASH=change-me
# TINYAUTH_GITHUB_CLIENT_ID=
# TINYAUTH_GITHUB_CLIENT_SECRET=
# TINYAUTH_GOOGLE_CLIENT_ID=
# TINYAUTH_GOOGLE_CLIENT_SECRET=

# ── AI 模型配置（至少填一个，也可全部填入） ──
# 云端 API 单独配置
# OPENAI_API_KEY=sk-your-openai-key
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# CLAUDE_API_KEY=sk-your-claude-key

# 或使用统一代理中转
# AI_RELAY_URL=http://AGENT_PROXY_HOST:3000/v1
# AGENT_PROXY_KEY=sk-your-agent-proxy-key

# ── 模型名称覆盖（可选） ──
# OPENAI_MODEL=gpt-4o
# DEEPSEEK_MODEL=deepseek-chat
# CLAUDE_MODEL=claude-sonnet-4
