# Rust
rust/target/
target/

# Next.js / Node
nextjs/node_modules/
nextjs/.next/
nextjs/out/
nextjs/build/
nextjs/next-env.d.ts
nextjs/.pnpm-store/
*.tsbuildinfo

# Dependencies (explicit for monorepo)
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Sensitive data
**/apikeys.json
**/call_records.yaml
data/lmstudio.json
*.db
*.db-shm
*.db-wal

# Config with secrets
config/*.local.yaml
*.local.json
*.local.toml

# Environment
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Misc
*.pem
nohup.out

# Souls — public repo only ships two demo souls; all others live in internal repo
# Internal souls are managed via data/souls-internal/ (not tracked by git)
# Deploy with: WANMINFAN_SOULS_INTERNAL_DIR=/path/to/internal-souls
data/souls-internal/

# Runtime artifacts
# 忽略运行时数据但保留目录结构（.gitkeep）
data/archive/**
!data/archive/.gitkeep
data/db/**
!data/db/.gitkeep
data/exports/
data/default-model.json
rust/data/archive/**
!rust/data/.gitkeep
rust/data/souls/**
scripts/__pycache__/

# 全局保留 .gitkeep 目录标记
!.gitkeep

# Build artifacts
dist/
*.zip

# CodeGraph index
.codegraph/
graphify-out/
