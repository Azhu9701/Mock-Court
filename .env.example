# ── Snake Skin 环境变量配置 ──
# 复制本文件为 .env 并填入实际值

# ── LM Studio 本地模型配置（推荐） ──
# 模型名称，如 qwen/qwen3.5-9b、qwen/qwen3.6-27b 等
LMSTUDIO_MODEL=qwen/qwen3.5-9b

# ── 云端 API 配置（至少填一个） ──
# 将 API Key 写入 data/apikeys.json 或在此填入
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# OPENAI_API_KEY=sk-your-openai-key
# CLAUDE_API_KEY=sk-your-claude-key

# ── 部署域名（Docker 部署时） ──
# DOMAIN=localhost

# ── 服务端配置（源码模式） ──
# SERVER_HOST=127.0.0.1
# SERVER_PORT=3096
# NEXTJS_PORT=3000

# ── 开发模式 ──
# NODE_ENV=development
# RUST_LOG=info
