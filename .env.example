# ── Snake Skin 环境变量配置 ──
# 复制本文件为 .env 并填入实际值

# ── LM Studio 本地模型配置（推荐，零 API 费用） ──
# 模型名称，如 qwen/qwen3.5-9b、qwen/qwen3.6-27b 等
LMSTUDIO_MODEL=qwen/qwen3.5-9b
# LM Studio 服务器地址（Docker 中默认通过 host.docker.internal 连接宿主机）
LMSTUDIO_HOST=http://host.docker.internal:1234

# ── 云端 API 配置（至少填一个，也可都不填只用 LM Studio） ──
# 方式 A：分别填入各平台 Key（推荐，更灵活）
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_MODEL=deepseek-chat
# CLAUDE_API_KEY=sk-your-claude-key
# CLAUDE_MODEL=claude-sonnet-4

# 方式 B：统一代理 Key（如果你使用 AI 代理服务）
# AI_RELAY_URL=http://your-proxy-host:3000/v1

# ── 搜索配置（可选） ──
# 搜索引擎：bing | searxng（Docker 本地默认使用 searxng）
SEARCH_ENGINE=searxng
# SearXNG 内部密钥（仅 Docker 本地模式需要）
SEARXNG_SECRET=local-dev-searxng-secret-that-is-long-enough

# ── 服务端配置（源码模式开发时生效） ──
# SERVER_HOST=127.0.0.1
# SERVER_PORT=3096
# NEXTJS_PORT=3000

# ── 部署域名（生产 Docker 部署时） ──
# DOMAIN=localhost

# ── 日志级别 ──
RUST_LOG=info

# ── 开发模式 ──
# NODE_ENV=development
